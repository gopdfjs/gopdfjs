/** @jsxImportSource @wsxjs/wsx-core */

import { LightComponent, autoRegister } from '@wsxjs/wsx-core';
import styles from './App.css?inline';
import '@wsxjs/wsx-base-components';
import '@wsxjs/wsx-router';
import { sitePath } from './sitePaths';
import './components/layout/AppHeader.wsx';
import './components/layout/AppFooter.wsx';
import './components/pages/HomePage.wsx';
import './components/pages/PackagesPage.wsx';
import './components/pages/DocsPage.wsx';

@autoRegister({ tagName: 'gopdf-app' })
export default class App extends LightComponent {
  constructor() {
    super({
      styles,
      styleName: 'gopdf-app',
    });
  }

  render() {
    return (
      <div class="app-container">
        <gopdf-app-header />
        <wsx-router>
          <wsx-view route={sitePath('/')} component="home-page" />
          <wsx-view route={sitePath('/packages')} component="packages-page" />
          <wsx-view route={sitePath('/docs/:category/:page')} component="docs-page" />
        </wsx-router>
        <gopdf-app-footer />
      </div>
    );
  }
}
