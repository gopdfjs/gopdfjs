{
  "name": "@gopdfjs/site",
  "version": "0.1.0",
  "description": "GoPDF.js docs landing (GitHub Pages)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm generate:sitemap && cross-env VITE_BASE=/gopdfjs/ vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "generate:sitemap": "tsx scripts/generate-sitemap.ts",
    "lint": "eslint src --ext .ts,.wsx",
    "lint:fix": "eslint src --ext .ts,.wsx --fix"
  },
  "dependencies": {
    "@wsxjs/wsx-base-components": "^0.0.26",
    "@wsxjs/wsx-core": "^0.0.26",
    "@wsxjs/wsx-i18next": "^0.0.26",
    "@wsxjs/wsx-press": "^0.0.26",
    "@wsxjs/wsx-router": "^0.0.26",
    "i18next": "^23.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@wsxjs/wsx-vite-plugin": "^0.0.26",
    "cross-env": "^7.0.3",
    "fs-extra": "^11.3.0",
    "globals": "^16.5.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "unocss": "^66.5.12",
    "vite": "^7.3.1",
    "vitest": "^1.6.1"
  }
}
