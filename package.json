{
  "name": "gopdf-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "pangu",
    "dev:turbo": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "build:wasm": "pnpm --filter=@gopdfjs/wasm build:wasm",
    "build:wasm:dev": "pnpm --filter=@gopdfjs/wasm build:wasm:dev",
    "test:rust": "cargo test --workspace",
    "pretest:e2e": "test -f packages/wasm/pkg/gopdf_wasm_bg.wasm || pnpm build:wasm",
    "validate": "pnpm test:rust && python3 .spec/scripts/check-layer-deps.py && python3 .spec/scripts/check-public-exports.py && pnpm test && pnpm lint && pnpm build",
    "test": "pnpm test:rust && python3 .spec/scripts/check-layer-deps.py && python3 .spec/scripts/check-public-exports.py && turbo run test",
    "check:layer-deps": "python3 .spec/scripts/check-layer-deps.py",
    "check:public-exports": "python3 .spec/scripts/check-public-exports.py",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "playwright test -c apps/demo/e2e/playwright.config.ts",
    "fixtures:download": "bash scripts/download-e2e-fixtures.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@gopdfjs/fixtures": "workspace:*",
    "@playwright/test": "^1.55.1",
    "@systembug/pangu": "^0.0.13",
    "husky": "^9.1.7",
    "turbo": "latest"
  }
}
