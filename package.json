{
  "name": "gopdf-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "pangu",
    "release": "qingniao",
    "changeset": "changeset",
    "dev:turbo": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "cargo fmt --all",
    "format:check": "cargo fmt --all -- --check",
    "typecheck": "pnpm --filter=@gopdfjs/site typecheck",
    "build:wasm": "pnpm --filter=@gopdfjs/wasm build:wasm",
    "build:wasm:dev": "pnpm --filter=@gopdfjs/wasm build:wasm:dev",
    "test:rust": "cargo test --workspace",
    "pretest:e2e": "test -f packages/wasm/pkg/gopdf_wasm_bg.wasm || pnpm build:wasm",
    "validate": "pnpm test:rust && node scripts/check-layer-deps.mjs && node scripts/check-public-exports.mjs && pnpm test && pnpm lint && pnpm build",
    "test": "pnpm test:rust && node scripts/check-layer-deps.mjs && node scripts/check-public-exports.mjs && turbo run test",
    "check:layer-deps": "node scripts/check-layer-deps.mjs",
    "check:public-exports": "node scripts/check-public-exports.mjs",
    "check:vite-sanity": "node .claude/skills/gopdf-vite-sanity/scripts/vite-sanity-check.mjs",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "playwright test -c apps/demo/e2e/playwright.config.ts",
    "fixtures:download": "bash scripts/download-e2e-fixtures.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@gopdfjs/fixtures": "workspace:*",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.55.1",
    "@systembug/pangu": "^0.1.0",
    "@systembug/qingniao": "^0.1.0",
    "husky": "^9.1.7",
    "rollup": "^4.52.4",
    "rollup-plugin-dts": "^6.2.3",
    "turbo": "latest"
  }
}
