{
  "name": "gopdf-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "pangu",
    "dev:turbo": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "build:wasm": "PATH=\"$HOME/.cargo/bin:$PATH\" wasm-pack build crates/pdf-wasm --target web --out-dir packages/pdf-wasm/pkg --release",
    "build:wasm:dev": "PATH=\"$HOME/.cargo/bin:$PATH\" wasm-pack build crates/pdf-wasm --target web --out-dir packages/pdf-wasm/pkg --dev",
    "test:rust": "cargo test --workspace",
    "pretest:e2e": "test -f packages/pdf-wasm/pkg/pdf_wasm_bg.wasm || pnpm build:wasm",
    "validate": "pnpm test:rust && pnpm test && pnpm lint && pnpm build",
    "locale:check": "node packages/locale-cli/bin/gopdf-locale.mjs check",
    "locale:sync": "node packages/locale-cli/bin/gopdf-locale.mjs sync --messages-dir=site/messages",
    "test": "pnpm test:rust && turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "playwright test -c .spec/e2e/playwright.config.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@systembug/pangu": "^0.0.13",
    "husky": "^9.1.7",
    "turbo": "latest"
  }
}
