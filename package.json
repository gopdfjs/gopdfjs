{
  "name": "gopdf-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "pangu",
    "dev:turbo": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "build:wasm": "PATH=\"$HOME/.cargo/bin:$PATH\" wasm-pack build crates/gopdf-wasm --target web --out-dir ../../packages/engine/pkg --release",
    "build:wasm:dev": "PATH=\"$HOME/.cargo/bin:$PATH\" wasm-pack build crates/gopdf-wasm --target web --out-dir ../../packages/engine/pkg --dev",
    "build:cli": "pnpm --filter=@gopdfjs/pdf-cli build",
    "test:rust": "cargo test --workspace",
    "pretest:e2e": "test -f packages/engine/pkg/gopdf_wasm_bg.wasm || pnpm build:wasm",
    "validate": "pnpm test:rust && pnpm test && pnpm lint && pnpm build",
    "test": "pnpm test:rust && turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "playwright test -c demos/react/e2e/playwright.config.ts",
    "fixtures:download": "bash scripts/download-e2e-fixtures.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@systembug/pangu": "^0.0.13",
    "husky": "^9.1.7",
    "turbo": "latest"
  }
}
