{
  "name": "@gopdfjs/site",
  "version": "0.1.0",
  "description": "GoPDF.js official site — full WSX stack forked from wsxjs/site, rebranded for @gopdfjs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "cross-env NODE_ENV=production GITHUB_PAGES=true vite build",
    "build:pages:domain": "cross-env NODE_ENV=production GITHUB_PAGES=true CUSTOM_DOMAIN=true vite build",
    "preview": "vite preview",
    "deploy:pages": "pnpm build:pages:domain && gh-pages -d dist",
    "test": "vitest --run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@calenderjs/calendar": "^0.0.2",
    "@calenderjs/core": "^0.0.2",
    "@calenderjs/event-dsl": "^0.0.2",
    "@calenderjs/event-model": "^0.0.2",
    "@calenderjs/event-runtime": "^0.0.2",
    "@editorjs/editorjs": "^2.29.1",
    "@editorjs/header": "^2.8.8",
    "@editorjs/paragraph": "^2.11.7",
    "@slidejs/context": "^0.1.8",
    "@slidejs/core": "^0.1.8",
    "@slidejs/dsl": "^0.1.8",
    "@slidejs/editor": "^0.1.8",
    "@slidejs/runner": "^0.1.8",
    "@slidejs/runner-splide": "^0.1.8",
    "@slidejs/runner-swiper": "^0.1.8",
    "@slidejs/theme": "^0.1.8",
    "@unocss/preset-attributify": "^66.3.3",
    "@unocss/preset-uno": "^66.3.3",
    "@wsxjs/wsx-base-components": "^0.1.1",
    "@wsxjs/wsx-core": "^0.1.1",
    "@wsxjs/wsx-i18next": "^0.1.1",
    "@wsxjs/wsx-marked-components": "^0.1.1",
    "@wsxjs/wsx-press": "^0.1.1",
    "@wsxjs/wsx-router": "^0.1.1",
    "@wsxjs/wsx-theme": "^0.1.1",
    "i18next": "^23.0.0",
    "i18next-browser-languagedetector": "^7.0.0",
    "i18next-http-backend": "^2.0.0",
    "marked": "^17.0.1",
    "monaco-editor": "^0.45.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/ui": "^3.2.4",
    "@wsxjs/eslint-plugin-wsx": "^0.1.1",
    "@wsxjs/wsx-vite-plugin": "^0.1.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.0.0",
    "globals": "^15.14.0",
    "gh-pages": "^6.1.1",
    "happy-dom": "^18.0.1",
    "typescript": "^5.0.0",
    "unocss": "^66.3.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
