{
  "name": "@gopdfjs/engine",
  "version": "0.1.0",
  "description": "Consumer PDF API — createEngine(adapter) builds runtime from adapter, wires plugin-* into Gopdf.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "vite build",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@cantoo/pdf-lib": "^2.6.5",
    "diff-match-patch": "^1.0.5",
    "docx": "^9.6.1",
    "dompurify": "^3.4.11",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "marked": "^18.0.5",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.296",
    "pixelmatch": "^7.2.0",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "@gopdfjs/adapter": "workspace:*",
    "@gopdfjs/adapter-node": "workspace:*",
    "@gopdfjs/model": "workspace:*",
    "@gopdfjs/plugin": "workspace:*",
    "@gopdfjs/plugin-annotate": "workspace:*",
    "@gopdfjs/plugin-author": "workspace:*",
    "@gopdfjs/plugin-compare": "workspace:*",
    "@gopdfjs/plugin-extract": "workspace:*",
    "@gopdfjs/plugin-grayscale": "workspace:*",
    "@gopdfjs/plugin-inspect": "workspace:*",
    "@gopdfjs/plugin-redact": "workspace:*",
    "@gopdfjs/plugin-repair": "workspace:*",
    "@gopdfjs/plugin-shrink": "workspace:*",
    "@gopdfjs/plugin-struct": "workspace:*",
    "@gopdfjs/runtime": "workspace:*",
    "@gopdfjs/fixtures": "workspace:*",
    "@vitest/coverage-v8": "^3.0.0",
    "rollup": "^4.52.4",
    "rollup-plugin-dts": "^6.2.3",
    "typescript": "^5",
    "vite": "^7.2.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ]
}
