{
  "name": "@gopdfjs/engine",
  "version": "0.1.0",
  "private": true,
  "description": "Consumer PDF API — createEngine(adapter) builds runtime from adapter, wires plugin-* into Gopdf.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./compare": "./src/compare.ts",
    "./render": "./src/renderPage.ts",
    "./pkg/*": "./pkg/*"
  },
  "scripts": {
    "test": "vitest run"
  },
  "dependencies": {
    "@gopdfjs/plugin-author": "workspace:*",
    "@gopdfjs/plugin-annotate": "workspace:*",
    "@gopdfjs/plugin-compare": "workspace:*",
    "@gopdfjs/plugin-extract": "workspace:*",
    "@gopdfjs/plugin-grayscale": "workspace:*",
    "@gopdfjs/plugin-inspect": "workspace:*",
    "@gopdfjs/adapter": "workspace:*",
    "@gopdfjs/model": "workspace:*",
    "@gopdfjs/plugin": "workspace:*",
    "@gopdfjs/runtime": "workspace:*",
    "@gopdfjs/plugin-redact": "workspace:*",
    "@gopdfjs/plugin-repair": "workspace:*",
    "@gopdfjs/plugin-shrink": "workspace:*",
    "@gopdfjs/plugin-struct": "workspace:*"
  },
  "devDependencies": {
    "@gopdfjs/adapter-node": "workspace:*",
    "@gopdfjs/fixtures": "workspace:*",
    "typescript": "^5",
    "vitest": "^3.0.0"
  }
}
