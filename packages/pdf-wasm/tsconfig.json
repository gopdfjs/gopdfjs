{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "WebWorker"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "./pkg/pdf_wasm.js": ["./pkg/pdf_wasm.d.ts", "./pkg.d.ts"]
    }
  },
  "include": ["*.ts", "src/**/*.ts"]
}
