{
  "name": "@gopdfjs/adapter-browser",
  "version": "0.1.0",
  "description": "Browser GopdfAdapter — loads shared @gopdfjs/wasm (init fetches .wasm), pdf.js, canvas. Run pnpm --filter=@gopdfjs/wasm build:wasm first.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "build": "vite build",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@gopdfjs/adapter": "workspace:*",
    "@gopdfjs/engine": "workspace:*",
    "@gopdfjs/model": "workspace:*",
    "@gopdfjs/wasm": "workspace:*",
    "pdfjs-dist": "^5.4.296"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^7.2.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ]
}
