    "@gopdfjs/wasm": "workspace:*",
    "@napi-rs/canvas": "0.1.97",
    "pdfjs-dist": "^5.4.296",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@gopdfjs/fixtures": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
