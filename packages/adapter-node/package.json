{
  "name": "@gopdfjs/adapter-node",
  "version": "0.1.0",
  "description": "Node GopdfAdapter — loads shared @gopdfjs/wasm (feeds .wasm bytes to init), pdf.js, napi-canvas, OCR. Run pnpm --filter=@gopdfjs/wasm build:wasm first.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "build": "vite build",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@gopdfjs/adapter": "workspace:*",
    "@gopdfjs/engine": "workspace:*",
    "@gopdfjs/model": "workspace:*",
    "@gopdfjs/wasm": "workspace:*",
    "@napi-rs/canvas": "0.1.97",
    "pdfjs-dist": "^5.4.296",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@gopdfjs/fixtures": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.2.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ]
}
